{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "sim",
            "type": "shell",
            "command": "uv run robotpy sim",
            "detail": "Run the robot simulator (with GUI, via robotpy CLI)",
            "group": "test"
        },
        {
            "label": "deploy",
            "type": "shell",
            "command": "uv run robotpy deploy",
            "detail": "Deploy code to roboRIO",
            "group": "none"
        },
        {
            "label": "test",
            "type": "shell",
            "command": "uv run python -m pytest tests/ -v",
            "detail": "Run pytest suite",
            "group": "test"
        },
        {
            "label": "lint",
            "type": "shell",
            "command": "uv run ruff check .",
            "detail": "Lint with ruff",
            "group": "build"
        },
        {
            "label": "typecheck",
            "type": "shell",
            "command": "uv run python -m mypy . --strict",
            "detail": "Type-check with mypy --strict",
            "group": "build"
        },
        {
            "label": "check-all",
            "type": "shell",
            "command": "uv run ruff check . && uv run python -m mypy . --strict && uv run python -m pytest tests/ -q",
            "detail": "Run lint, typecheck, and tests in sequence",
            "group": "test",
            "dependsOn": ["lint", "typecheck", "test"]
        }
    ]
}
